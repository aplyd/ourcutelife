{
  "cli": { "version": ">= 20.2.0", "appVersionSource": "remote" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "resourceClass": "m-medium" }
    },
    "preview": {
      "distribution": "internal",
      "ios": { "resourceClass": "m-medium" }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-medium",
        "buildConfiguration": "Release"
      },
      "env": {
        "EXPO_NO_DOTENV": "1",
        "APP_ENV": "production"
      },
      "channel": "production",
      "environment": "production",
      "distribution": "store"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6781453603",
        "appleTeamId": "X5KBCB6WPT"
      }
    }
  }
}
